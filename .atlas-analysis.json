  "keyFeatures": [
    "7TV Name Paints — custom animated username rendering in chat",
    "7TV Personal Emotes — subscriber-exclusive personal emote sets",
    "7TV Animated Profile Avatars — animated avatars in usercards",
    "4x image support for 7TV and FFZ emotes",
    "Lua Plugin System — extend Chatterino with sandboxed Lua scripts",
    "Custom themes via JSON schema",
    "Hotkey customization for all actions",
    "Advanced message filtering and highlight rules",
    "Experimental Kick.com chat support",
    "AVIF image format support for modern emote rendering"
  ],
  "publicApiSurface": [
    "c2.Channel — interact with Twitch/IRC channels from plugins",
    "c2.HTTPRequest — make HTTP requests from plugins",
    "c2.WebSocket — connect to WebSocket servers from plugins",
    "c2.Message.new() — create rich chat messages from plugins",
    "c2.register_command() — register custom chat commands",
    "c2.register_callback() — listen for completion and other events",
    "c2.current_account() — get the current Twitch account",
    "c2.log() — write to the Chatterino log",
    "chatterino.json module — JSON parse/stringify for plugins",
    "Plugin permissions: FilesystemRead, FilesystemWrite, Network"
  ]
